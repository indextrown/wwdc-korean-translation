{
  "manifest_version": 3,
  "name": "WWDC 한글 번역",
  "description": "WWDC 영상의 영어 자막을 한국어로 실시간 번역해 영상 위에 표시합니다.",
  "version": "0.1.0",
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    },
    "default_popup": "popup/index.html",
    "default_title": "WWDC 한글 번역"
  },
  "options_page": "options/index.html",
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://developer.apple.com/videos/play/*",
        "https://developer.apple.com/*/videos/play/*"
      ],
      "js": ["content/content-script.js"],
      "css": ["content/content-style.css"],
      "run_at": "document_start"
    }
  ],
  "host_permissions": [
    "https://developer.apple.com/*",
    "https://api.cognitive.microsofttranslator.com/*",
    "https://translation.googleapis.com/*",
    "https://api-free.deepl.com/*",
    "https://api.deepl.com/*",
    "https://papago.apigw.ntruss.com/*",
    "https://*.amazonaws.com/*",
    "https://libretranslate.com/*"
  ],
  "permissions": ["storage", "activeTab"],
  "commands": {
    "toggle-subtitles": {
      "suggested_key": {
        "default": "Alt+Shift+S",
        "mac": "Alt+Shift+S"
      },
      "description": "WWDC 한글 번역 켜기/끄기"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
